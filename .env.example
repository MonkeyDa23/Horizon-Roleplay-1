API_SECRET_KEY=YOUR_LONG_RANDOM_SECURE_KEY
SIGNATURE_KEY=YOUR_LONG_RANDOM_SECURE_KEY
MTA_BOT_KEY=YOUR_LONG_RANDOM_SECURE_KEY
BOT_WEB_KEY=YOUR_LONG_RANDOM_SECURE_KEY
ENCRYPTION_KEY=YOUR_LONG_RANDOM_SECURE_KEY

# Supabase Configuration
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
