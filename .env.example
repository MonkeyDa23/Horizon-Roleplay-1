# Captcha and Security (Vercel)
VITE_SITE_URL=https://your-public-site-url.com
VITE_HCAPTCHA_SITE_KEY=YOUR_PUBLIC_SITE_KEY_HERE
HCAPTCHA_SECRET_KEY=YOUR_SECRET_KEY_HERE
